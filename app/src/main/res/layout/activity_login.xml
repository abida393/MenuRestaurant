<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F0EB"
    android:orientation="vertical"
    android:padding="32dp">

    <!-- Top spacer -->
    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Title: "Savoria Admin" in serif italic -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="serif"
        android:text="@string/savoria_admin"
        android:textColor="#A02020"
        android:textSize="48sp"
        android:textStyle="bold|italic" />

    <!-- Red underline accent -->
    <View
        android:layout_width="56dp"
        android:layout_height="3dp"
        android:layout_marginTop="8dp"
        android:background="#A02020" />

    <!-- Large space between title and form -->
    <Space
        android:layout_width="match_parent"
        android:layout_height="40dp" />

    <!-- Subtitle -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif"
        android:letterSpacing="0.08"
        android:lineSpacingMultiplier="1.4"
        android:text="@string/please_enter_your_credentials_to_access_the_maitre_d_dashboard"
        android:textColor="#616161"
        android:textSize="11sp"
        android:textStyle="bold" />

    <Space
        android:layout_width="match_parent"
        android:layout_height="40dp" />

    <!-- Email label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:letterSpacing="0.1"
        android:text="@string/corporate_email"
        android:textColor="#616161"
        android:textSize="10sp"
        android:textStyle="bold"
        tools:ignore="SmallSp" />

    <!-- Email icon + field row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_login_input"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="14dp">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:contentDescription="@string/todo"
            android:src="@android:drawable/ic_dialog_email"
            app:tint="#AAAAAA"
            tools:ignore="ImageContrastCheck" />

        <EditText
            android:id="@+id/et_email"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:autofillHints=""
            android:background="@android:color/transparent"
            android:hint="@string/manager_savoria_com"
            android:inputType="textEmailAddress"
            android:minHeight="48dp"
            android:textColor="#2C2C2A"
            android:textColorHint="#546E7A"
            android:textSize="16sp"
            tools:ignore="VisualLintTextFieldSize" />
    </LinearLayout>

    <Space
        android:layout_width="match_parent"
        android:layout_height="20dp" />

    <!-- Password label row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:letterSpacing="0.1"
            android:text="@string/access_key"
            android:textColor="#616161"
            android:textSize="10sp"
            android:textStyle="bold"
            tools:ignore="SmallSp" />

        <TextView
            android:id="@+id/tv_recover"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:letterSpacing="0.08"
            android:text="@string/recover_password"
            android:textColor="#A02020"
            android:textSize="9sp"
            android:textStyle="bold"
            tools:ignore="SmallSp" />
    </LinearLayout>

    <!-- Password icon + field row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_login_input"
        android:contentDescription="@string/todo3"
        android:gravity="center_vertical"
        android:importantForAccessibility="no"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="14dp">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:contentDescription="@string/todo2"
            android:src="@android:drawable/ic_lock_idle_lock"
            app:tint="#AAAAAA"
            tools:ignore="ImageContrastCheck" />

        <EditText
            android:id="@+id/et_password"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:autofillHints=""
            android:background="@android:color/transparent"
            android:hint="@string/Pass"
            android:inputType="textPassword"
            android:minHeight="48dp"
            android:textColor="#2C2C2A"
            android:textColorHint="#546E7A"
            android:textSize="16sp"
            tools:ignore="VisualLintTextFieldSize" />
    </LinearLayout>

    <Space
        android:layout_width="match_parent"
        android:layout_height="40dp" />

    <!-- Login button -->
    <Button
        android:id="@+id/btn_login"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@drawable/bg_login_button"
        android:letterSpacing="0.15"
        android:stateListAnimator="@null"
        android:text="@string/enter_workspace"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold"
        tools:ignore="VisualLintButtonSize" />

    <!-- Error message -->
    <TextView
        android:id="@+id/tv_error"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:textColor="#C0392B"
        android:textSize="14sp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tv_demo_accounts"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:lineSpacingMultiplier="1.3"
        android:text="@string/login_demo_accounts"
        android:textColor="#888880"
        android:textSize="11sp" />

    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2" />

    <!-- Footer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:lineSpacingMultiplier="1.4"
            android:text="@string/secure_administrative_portal_all_access_is_logged_and_monitored"
            android:textColor="#546E7A"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/need_assistance"
                android:textColor="#546E7A"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tv_contact_admin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/contact_system_administrator"
                android:textColor="#A02020"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <Space
        android:layout_width="match_parent"
        android:layout_height="24dp" />

</LinearLayout>
