<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card_white"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="14dp"
    android:layout_marginBottom="8dp">

    <!-- Dish image -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/iv_dish"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:scaleType="centerCrop"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.SmallComponent"
        tools:src="@mipmap/ic_launcher" />

    <!-- Name + meta -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_dish_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#1C1C1A"
            android:textSize="15sp"
            android:textStyle="bold"
            tools:text="Signature Beef Tartare" />

        <TextView
            android:id="@+id/tv_dish_meta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="#999990"
            android:textSize="12sp"
            tools:text="Appetizers • 42 orders today" />
    </LinearLayout>

    <!-- Price + Badge -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="end|center_vertical"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_dish_price"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="serif"
            android:textColor="#1C1C1A"
            android:textSize="15sp"
            android:textStyle="bold"
            tools:text="$24.00" />

        <TextView
            android:id="@+id/tv_stock_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_badge_green"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp"
            android:textSize="9sp"
            android:textStyle="bold"
            tools:text="IN STOCK"
            tools:textColor="#22A060" />
    </LinearLayout>

</LinearLayout>
