<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/savoria_card"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:strokeColor="#E8E4DF"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_order_id"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="serif"
                    android:textColor="@color/savoria_text_primary"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    tools:text="#D8EE24" />

                <TextView
                    android:id="@+id/tv_order_time"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/savoria_text_muted"
                    android:textSize="13sp"
                    tools:text="14:32" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_order_mode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_badge_light_blue"
                android:paddingHorizontal="10dp"
                android:paddingVertical="5dp"
                android:textColor="#1A5FA0"
                android:textSize="10sp"
                android:textStyle="bold"
                tools:text="SUR PLACE" />

            <TextView
                android:id="@+id/tv_order_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:textColor="@android:color/white"
                android:textSize="11sp"
                android:textStyle="bold"
                tools:text="EN ATTENTE" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="12dp"
            android:background="#F0EBE6" />

        <TextView
            android:id="@+id/tv_order_items"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:lineSpacingMultiplier="1.35"
            android:textColor="@color/savoria_text_primary"
            android:textSize="15sp"
            tools:text="• 2× Tartare de bœuf" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_start_preparation"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="14dp"
            android:backgroundTint="#A02020"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="@string/chef_btn_start_cooking"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            app:cornerRadius="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_mark_ready"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:backgroundTint="#2E7D32"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="@string/chef_btn_ready"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            app:cornerRadius="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_send_excuse"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="@string/btn_send_excuse"
            android:textAllCaps="false"
            android:textColor="@color/savoria_text_secondary"
            android:textSize="13sp"
            app:cornerRadius="12dp"
            app:strokeColor="#CCCCCC" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
