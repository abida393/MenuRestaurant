<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F0EB">

    <!-- ── Scrollable content ── -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="90dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- ── TOP BAR ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/iv_back"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_sort_by_size"
                    android:tint="#1C1C1A" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:fontFamily="serif"
                    android:text="Ajouter / Modifier un Plat"
                    android:textColor="#1C1C1A"
                    android:textSize="22sp"
                    android:textStyle="bold|italic" />

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="16dp"
                    android:src="@android:drawable/ic_popup_reminder"
                    android:tint="#1C1C1A" />

                <!-- Avatar circle -->
                <TextView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_stat_card_dark"
                    android:gravity="center"
                    android:text="A"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- ── PHOTO UPLOADER ── -->
            <FrameLayout
                android:id="@+id/fl_photo_upload"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_photo_upload"
                android:clipChildren="false">

                <!-- Dish image (hidden until selected) -->
                <ImageView
                    android:id="@+id/iv_dish_photo"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:visibility="gone" />

                <!-- Circle glass + camera icon -->
                <LinearLayout
                    android:layout_width="160dp"
                    android:layout_height="160dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_circle_glass"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@android:drawable/ic_menu_camera"
                        android:tint="#A02020" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:letterSpacing="0.08"
                        android:text="MODIFIER LA PHOTO"
                        android:textColor="#FFFFFF"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:gravity="center"
                        android:text="Recommandé : 1200×1200 px"
                        android:textColor="#CCFFFFFF"
                        android:textSize="10sp" />
                </LinearLayout>
            </FrameLayout>

            <!-- ── VISIBILITY & PROMOTIONS ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_form_card"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.1"
                    android:text="VISIBILITÉ &amp; PROMOTIONS"
                    android:textColor="#999990"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <!-- Toggle: Available -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Disponible"
                            android:textColor="#1C1C1A"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Visible dans le menu client"
                            android:textColor="#999990"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_available"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        app:thumbTint="#FFFFFF"
                        app:trackTint="@color/switch_track_color" />
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="12dp"
                    android:background="#F0EEEB" />

                <!-- Toggle: Dish of the Day -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Plat du jour"
                            android:textColor="#1C1C1A"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Mis en avant sur la page d'accueil"
                            android:textColor="#999990"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_dish_of_day"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="false"
                        app:thumbTint="#FFFFFF"
                        app:trackTint="@color/switch_track_color" />
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="12dp"
                    android:background="#F0EEEB" />

                <!-- Toggle: Featured -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="En vedette"
                            android:textColor="#1C1C1A"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Marqué comme 'Choix du Chef'"
                            android:textColor="#999990"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_featured"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        app:thumbTint="#FFFFFF"
                        app:trackTint="@color/switch_track_color" />
                </LinearLayout>
            </LinearLayout>

            <!-- ── FORM FIELDS ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_form_card"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Dish Name -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.1"
                    android:text="NOM DU PLAT"
                    android:textColor="#A02020"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/et_dish_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:background="@android:color/transparent"
                    android:fontFamily="serif"
                    android:hint="ex. Saint-Jacques poêles…"
                    android:textColorHint="#CCCCCC"
                    android:inputType="textCapSentences"
                    android:textColor="#1C1C1A"
                    android:textSize="20sp"
                    android:textStyle="italic" />

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="16dp"
                    android:background="#F0EEEB" />

                <!-- Category + Price row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Category -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:letterSpacing="0.1"
                            android:text="CATÉGORIE"
                            android:textColor="#999990"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <Spinner
                            android:id="@+id/spinner_category"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@android:color/transparent"
                            android:textSize="15sp" />
                    </LinearLayout>

                    <!-- Regular Price -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:letterSpacing="0.1"
                            android:text="PRIX NORMAL"
                            android:textColor="#999990"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="$ "
                                android:textColor="#999990"
                                android:textSize="16sp" />

                            <EditText
                                android:id="@+id/et_regular_price"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@android:color/transparent"
                                android:hint="0.00"
                                android:textColorHint="#CCCCCC"
                                android:inputType="numberDecimal"
                                android:textColor="#1C1C1A"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="16dp"
                    android:background="#F0EEEB" />

                <!-- Promo Price -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.1"
                    android:text="PRIX PROMO (OPTIONNEL)"
                    android:textColor="#999990"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$ "
                        android:textColor="#999990"
                        android:textSize="16sp" />

                    <EditText
                        android:id="@+id/et_promo_price"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:hint="0.00"
                        android:textColorHint="#CCCCCC"
                        android:inputType="numberDecimal"
                        android:textColor="#1C1C1A"
                        android:textSize="16sp" />
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="16dp"
                    android:background="#F0EEEB" />

                <!-- Description -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.1"
                    android:text="DESCRIPTION"
                    android:textColor="#A02020"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/et_description"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:layout_marginTop="8dp"
                    android:background="@android:color/transparent"
                    android:gravity="top"
                    android:hint="Décrivez le plat — ingrédients, préparation, profil gustatif…"
                    android:textColorHint="#CCCCCC"
                    android:inputType="textMultiLine|textCapSentences"
                    android:lineSpacingMultiplier="1.5"
                    android:textColor="#1C1C1A"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- ── ALLERGEN DECLARATIONS ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:letterSpacing="0.1"
                android:text="DÉCLARATIONS ALLERGIQUES"
                android:textColor="#999990"
                android:textSize="10sp"
                android:textStyle="bold" />

            <!-- Chip flex layout -->
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chip_group_allergens"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:chipSpacingHorizontal="8dp"
                app:chipSpacingVertical="8dp">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_seafood"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fruits de mer"
                    android:textSize="13sp"
                    app:chipBackgroundColor="@color/chip_bg_color"
                    app:chipStrokeColor="@color/chip_stroke_color"
                    app:chipStrokeWidth="1.5dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_dairy"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lactose"
                    android:textSize="13sp"
                    app:chipBackgroundColor="@color/chip_bg_color"
                    app:chipStrokeColor="@color/chip_stroke_color"
                    app:chipStrokeWidth="1.5dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_gluten"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sans Gluten"
                    android:textSize="13sp"
                    app:chipBackgroundColor="@color/chip_bg_color"
                    app:chipStrokeColor="@color/chip_stroke_color"
                    app:chipStrokeWidth="1.5dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_nuts"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fruits à coque"
                    android:textSize="13sp"
                    app:chipBackgroundColor="@color/chip_bg_color"
                    app:chipStrokeColor="@color/chip_stroke_color"
                    app:chipStrokeWidth="1.5dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_soy"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Soja"
                    android:textSize="13sp"
                    app:chipBackgroundColor="@color/chip_bg_color"
                    app:chipStrokeColor="@color/chip_stroke_color"
                    app:chipStrokeWidth="1.5dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_vegan"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Végétalien"
                    android:textSize="13sp"
                    app:chipBackgroundColor="@color/chip_bg_color"
                    app:chipStrokeColor="@color/chip_stroke_color"
                    app:chipStrokeWidth="1.5dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_add_allergen"
                    style="@style/Widget.MaterialComponents.Chip.Action"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+"
                    android:textSize="18sp"
                    app:chipBackgroundColor="#F5F0EB"
                    app:chipStrokeColor="#DDDDDD"
                    app:chipStrokeWidth="1.5dp" />

            </com.google.android.material.chip.ChipGroup>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ── STICKY BOTTOM ACTIONS ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#F5F0EB"
        android:elevation="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingVertical="14dp">

        <Button
            android:id="@+id/btn_discard"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:letterSpacing="0.1"
            android:stateListAnimator="@null"
            android:text="ANNULER"
            android:textColor="#AAAAAA"
            android:textSize="13sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_save_dish"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_marginStart="12dp"
            android:layout_weight="2"
            android:background="@drawable/bg_btn_red_pill"
            android:stateListAnimator="@null"
            android:text="Enregistrer le Plat"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
