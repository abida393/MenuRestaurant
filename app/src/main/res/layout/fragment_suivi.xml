<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F0EB"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="serif"
        android:text="Suivi de commande"
        android:textColor="#A02020"
        android:textSize="26sp"
        android:textStyle="bold|italic" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Mise à jour en temps réel depuis la cuisine"
        android:textColor="#777770"
        android:textSize="13sp" />

    <!-- Order Progress Stepper -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_stepper"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="24dp"
        android:layout_marginHorizontal="32dp"
        android:paddingHorizontal="8dp">

        <!-- Step 1: Confirmé -->
        <View
            android:id="@+id/step_1_circle"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="@drawable/bg_step_circle_inactive"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/line_1" />

        <TextView
            android:id="@+id/tv_step_1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Confirmé"
            android:textColor="#999990"
            android:textSize="10sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/step_1_circle"
            app:layout_constraintStart_toStartOf="@id/step_1_circle" />

        <!-- Line 1 -->
        <View
            android:id="@+id/line_1"
            android:layout_width="0dp"
            android:layout_height="2dp"
            android:background="#E8E3DC"
            android:layout_marginTop="5dp"
            app:layout_constraintTop_toTopOf="@id/step_1_circle"
            app:layout_constraintStart_toEndOf="@id/step_1_circle"
            app:layout_constraintEnd_toStartOf="@+id/step_2_circle" />

        <!-- Step 2: En cuisine -->
        <View
            android:id="@+id/step_2_circle"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="@drawable/bg_step_circle_inactive"
            app:layout_constraintStart_toEndOf="@id/line_1"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/line_2" />

        <TextView
            android:id="@+id/tv_step_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="En cuisine"
            android:textColor="#999990"
            android:textSize="10sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/step_2_circle"
            app:layout_constraintStart_toStartOf="@id/step_2_circle"
            app:layout_constraintEnd_toEndOf="@id/step_2_circle" />

        <!-- Line 2 -->
        <View
            android:id="@+id/line_2"
            android:layout_width="0dp"
            android:layout_height="2dp"
            android:background="#E8E3DC"
            android:layout_marginTop="5dp"
            app:layout_constraintTop_toTopOf="@id/step_2_circle"
            app:layout_constraintStart_toEndOf="@id/step_2_circle"
            app:layout_constraintEnd_toStartOf="@+id/step_3_circle" />

        <!-- Step 3: Prêt (étape finale) -->
        <View
            android:id="@+id/step_3_circle"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="@drawable/bg_step_circle_inactive"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/line_2"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_step_3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Prêt"
            android:textColor="#999990"
            android:textSize="10sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="@id/step_3_circle"
            app:layout_constraintTop_toBottomOf="@id/step_3_circle" />

    </androidx.constraintlayout.widget.ConstraintLayout>


    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_suivi"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false" />

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/progress_suivi"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminate="true"
            android:visibility="gone"
            app:indicatorColor="#A02020" />

        <TextView
            android:id="@+id/tv_suivi_empty"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="Aucune commande active"
            android:textColor="#999990"
            android:visibility="gone" />
    </FrameLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_order_more"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:backgroundTint="#1C1C1A"
        android:text="Commander autre chose"
        android:textColor="#FFFFFF" />
</LinearLayout>
