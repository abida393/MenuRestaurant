<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/chef_root_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/savoria_cream"
    android:orientation="vertical">

    <include layout="@layout/layout_chef_toolbar" />

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/chef_nav_host_fragment"
        android:name="androidx.navigation.fragment.NavHostFragment"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        app:defaultNavHost="true"
        app:navGraph="@navigation/nav_chef" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/chef_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/savoria_card"
        app:itemIconTint="@color/chef_bottom_nav_color"
        app:itemTextColor="@color/chef_bottom_nav_color"
        app:menu="@menu/menu_chef_bottom_nav" />

</LinearLayout>
