<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:name=".SavoriaApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="Savoria"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.RestaurantManager">

        <!-- ══════════════════════════════════════════
             CLIENT ENTRY POINT — launches first
             ══════════════════════════════════════════ -->
        <activity
            android:name="com.savoria.app.ClientActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ══════════════════════════════════════════
             ADMIN LOGIN — reached via the icon button
             ══════════════════════════════════════════ -->
        <activity
            android:name="com.savoria.app.ui.admin.login.LoginActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- ══════════════════════════════════════════
             ADMIN DASHBOARD — reached after login
             ══════════════════════════════════════════ -->
        <activity
            android:name="com.savoria.app.MainActivity"
            android:exported="false" />

        <activity android:name=".ChefActivity" android:theme="@style/Theme.Savoria.NoActionBar" />

    </application>

</manifest>